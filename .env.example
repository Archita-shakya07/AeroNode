# Copy this file to .env and fill in your values.
# For local development in VS Code on Windows.

# PostgreSQL connection string.
# Example for a local PostgreSQL: postgres://username:password@localhost:5432/collabsphere
# Example for a free Supabase project: postgres://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=postgres://collab:collab@localhost:5432/collabsphere

# Backend API server port. Must match API_PORT used by the Vite proxy.
PORT=8080
API_PORT=8080

# Long random string for signing JWTs / session cookies.
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-characters

# Frontend dev server port and base path.
FRONTEND_PORT=5000
BASE_PATH=/

# Optional: only needed for the Files Hub feature.
# These are Replit-specific object storage paths and will not work outside Replit.
# Leave them empty if you only need auth, tasks, kanban, meetings, and themes.
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
